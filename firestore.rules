rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role (admin/staff), assignedChecklistId, praca
    //
    // Collection: checklistTemplates
    // Fields: id, title, description, praca, frequency, items, active
    //
    // Collection: submissions
    // Fields: id, templateId, userId, userName, praca, timestamp, responses, pdfUrl
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         request.auth.token.email == "santiago02061992@gmail.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'staff'] &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('assignedChecklistId' in data) || data.assignedChecklistId is string) &&
             (!('assignedChecklistIds' in data) || data.assignedChecklistIds is list) &&
             (!('praca' in data) || data.praca is string);
    }

    function isValidTemplate(data) {
      return data.title is string && data.title.size() > 0 &&
             data.praca is string &&
             data.items is list;
    }

    function isValidSubmission(data) {
      return data.templateId is string &&
             data.userId is string &&
             data.userName is string &&
             data.timestamp is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /checklistTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidTemplate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
