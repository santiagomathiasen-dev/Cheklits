{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (Admins and Staff)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "assignedChecklistId": { "type": "string", "description": "Specific checklist assigned to this user" },
        "praca": { "type": "string", "description": "Assigned station/section" }
      },
      "required": ["uid", "email", "role"]
    },
    "ChecklistTemplate": {
      "title": "Checklist Template",
      "description": "Definition of a checklist created by admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "praca": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "type": { "type": "string", "enum": ["checkbox", "temperature", "text"] },
              "requiredPhoto": { "type": "boolean" }
            }
          }
        },
        "active": { "type": "boolean" }
      }
    },
    "ChecklistSubmission": {
      "title": "Checklist Submission",
      "description": "A completed checklist by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "templateId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "praca": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "responses": {
          "type": "object",
          "description": "Map of item ID to response data (value, photoUrl)"
        },
        "pdfUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/checklistTemplates/{templateId}": {
      "schema": "ChecklistTemplate",
      "description": "Checklist definitions"
    },
    "/submissions/{submissionId}": {
      "schema": "ChecklistSubmission",
      "description": "Completed checklists"
    }
  }
}
